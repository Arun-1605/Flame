<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConnectApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/ConnectTypography.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Value converters ── -->

            <!-- string -> bool (non-empty = true) -->
            <converters:StringToBoolConverter  x:Key="StringToBoolConverter"
                xmlns:converters="clr-namespace:ConnectApp.Converters"/>

            <!-- bool inversion -->
            <converters:InvertedBoolConverter  x:Key="InvertedBoolConverter"
                xmlns:converters="clr-namespace:ConnectApp.Converters"/>

            <!-- Edit mode background -->
            <converters:EditBgConverter        x:Key="EditBgConverter"
                xmlns:converters="clr-namespace:ConnectApp.Converters"/>

            <!-- Mute button background -->
            <converters:MuteBgConverter        x:Key="MuteBgConverter"
                xmlns:converters="clr-namespace:ConnectApp.Converters"/>

            <!-- Input border named style (used inline in pages) -->
            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor"  Value="{StaticResource InputBackground}"/>
                <Setter Property="StrokeThickness"  Value="1"/>
                <Setter Property="Stroke"           Value="{StaticResource InputBorder}"/>
                <Setter Property="Padding"          Value="12,0"/>
                <Setter Property="HeightRequest"    Value="52"/>
                <Setter Property="Margin"           Value="0,0,0,4"/>
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="12"/>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
